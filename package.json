{
  "name": "obscurpilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloud-hybrid voice-controlled live production desktop platform",
  "license": "UNLICENSED",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "npm run build && npm --workspace @obscurpilot/desktop run start",
    "dev": "npm run build:types && npm --workspace @obscurpilot/desktop run dev",
    "build": "npm run build:types && npm --workspace @obscurpilot/desktop run build",
    "build:types": "tsc -b --pretty false",
    "clean": "tsc -b --clean && npm --workspace @obscurpilot/desktop run clean",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:contract": "vitest run tests/contract",
    "test:integration": "vitest run --config tests/integration/vitest.config.ts",
    "test:chaos": "vitest run --config tests/chaos/vitest.config.ts",
    "test:performance": "vitest run --config tests/performance/vitest.config.ts",
    "test:e2e": "playwright test",
    "supabase:start": "supabase start",
    "supabase:reset": "supabase db reset --local",
    "supabase:test": "supabase test db",
    "supabase:types": "supabase gen types typescript --local --schema public > packages/adapters-supabase/src/database.types.ts",
    "package:dir": "npm run build && npm --workspace @obscurpilot/desktop run package:dir",
    "audit:dependencies": "npm audit --omit=dev --audit-level=high",
    "audit:licenses": "license-checker-rseidelsohn --production --excludePrivatePackages --onlyAllow \"Apache-2.0;BSD-2-Clause;BSD-3-Clause;ISC;MIT;0BSD;BlueOak-1.0.0\"",
    "verify:static": "npm run typecheck && npm run lint && npm run format:check",
    "verify": "npm run verify:static && npm run test && npm run build",
    "verify:renderer-boundary": "node scripts/verify-renderer-secret-boundary.mjs",
    "supabase:upgrade-test": "supabase db reset --local --version 202607150000 && supabase migration up --local && supabase test db"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "axe-core": "4.12.1",
    "concurrently": "10.0.3",
    "electron": "43.1.1",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-security": "4.0.1",
    "globals": "17.7.0",
    "license-checker-rseidelsohn": "4.4.2",
    "prettier": "3.9.5",
    "rimraf": "6.1.3",
    "supabase": "2.109.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10",
    "wait-on": "9.0.10"
  }
}
