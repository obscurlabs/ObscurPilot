  "references": [
    { "path": "./packages/contracts" },
    { "path": "./packages/domain" },
    { "path": "./packages/adapters-obs" },
    { "path": "./packages/adapters-supabase" },
    { "path": "./packages/adapters-twitch" },
    { "path": "./packages/adapters-groq" }
  ]
