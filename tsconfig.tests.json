{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "lib": ["ES2023", "DOM"],
    "outDir": ".types/tests",
    "rootDir": ".",
    "skipLibCheck": true,
