    "apps/desktop/electron/windows-desktop-supervisor.ts",
    "apps/desktop/electron/sherpa-wake-word.ts",
    "apps/desktop/electron/wake-word-worker.ts",
    "apps/desktop/electron/wake-word-worker-client.ts",
    "apps/desktop/electron/deepgram-voice-agent.ts",
    "apps/desktop/electron/ipc-router.ts",
    "apps/desktop/electron/lifecycle.ts",
    "apps/desktop/electron/preload-api.ts",
