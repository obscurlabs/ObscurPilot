# ObscurPilot local development configuration.
# Copy values into .env. Never commit real credentials.
# These variables are loaded only by Electron main; no secret may use a VITE_ prefix.

# User-owned Groq credential (BYOK). Production persistence uses the OS vault.
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_REASONING_MODEL=openai/gpt-oss-120b
GROQ_REASONING_FALLBACK_MODEL=qwen/qwen3.6-27b

# Supabase URL and public/anonymous key. Authorization still requires Auth and RLS.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Public Twitch client identifier. Client secrets stay in a server-side function.
TWITCH_CLIENT_ID=
TWITCH_REDIRECT_URI=https://PROJECT_REF.supabase.co/functions/v1/twitch-oauth-callback

# Local OBS WebSocket connection. Keep OBS bound to loopback.
OBS_WEBSOCKET_URL=ws://127.0.0.1:4455
OBS_WEBSOCKET_PASSWORD=
# Optional absolute path used when ObscurPilot needs to launch OBS automatically.
# Example: C:\Program Files\obs-studio\bin\64bit\obs64.exe
OBS_EXECUTABLE_PATH=

# Non-secret runtime settings.
OBSCURPILOT_LOG_LEVEL=info
OBSCURPILOT_DEV_SERVER_URL=http://127.0.0.1:5173
