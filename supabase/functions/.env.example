# Server-only Edge Function secrets. Never copy these into the desktop root .env.
SUPABASE_SERVICE_ROLE_KEY=
OBSCURPILOT_DELETION_JOB_SECRET=

# Stage 7 Twitch OAuth. Store hosted values in Supabase Edge Function secrets.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=https://PROJECT_REF.supabase.co/functions/v1/twitch-oauth-callback
TWITCH_COMPLETION_URI=obscurpilot://oauth/twitch/callback
TWITCH_TOKEN_ENCRYPTION_KEY=
# Space-separated least-privilege scopes. Empty supports baseline public stream/channel events.
TWITCH_SCOPES=
